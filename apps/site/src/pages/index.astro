---
// Fallback for environments where the Cloudflare Pages Function
// (functions/index.ts) does not run (e.g. local dev without wrangler).
// In production the edge function returns a 302 before this page is served.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (function () {
        var lang = (navigator.language || '').toLowerCase().slice(0, 2);
        var locales = { cs: '/cs/', sk: '/sk/' };
        window.location.replace(locales[lang] || '/en/');
      })();
    </script>
    <meta http-equiv="refresh" content="0;url=/en/" />
  </head>
  <body></body>
</html>
